{
  "name": "ai-job-portal-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "ts-node-dev --transpile-only src/db/run-migrations.ts",
    "db:seed": "ts-node-dev --transpile-only src/db/run-seed.ts",
    "db:validate": "ts-node-dev --transpile-only src/db/validate-db.ts",
    "db:reset": "npm run db:migrate && npm run db:seed",
    "test:auth": "ts-node-dev --transpile-only src/db/test-auth-flows.ts",
    "test:rbac": "ts-node-dev --transpile-only src/db/test-rbac-flows.ts",
    "test:profile": "ts-node-dev --transpile-only src/db/test-profile-flows.ts",
    "test:jobs": "ts-node-dev --transpile-only src/db/test-job-flows.ts",
    "test:resumes": "ts-node-dev --transpile-only src/db/test-resume-flows.ts",
    "test:applications": "ts-node-dev --transpile-only src/db/test-application-flows.ts",
    "test:notifications": "ts-node-dev --transpile-only src/db/test-notification-flows.ts",
    "test:analytics": "ts-node-dev --transpile-only src/db/test-analytics-flows.ts",
    "test:dashboard": "ts-node-dev --transpile-only src/db/test-candidate-dashboard-flows.ts",
    "test:ai-analysis": "ts-node-dev --transpile-only src/db/test-ai-analysis-flows.ts",
    "test:match-engine": "ts-node-dev --transpile-only src/db/test-match-engine-flows.ts",
    "test:career-advisor": "ts-node-dev --transpile-only src/db/test-career-advisor-flows.ts",
    "test:openrouter": "ts-node-dev --transpile-only src/db/test-openrouter-provider.ts",
    "lint": "eslint src/ server.ts",
    "lint:fix": "eslint src/ server.ts --fix",
    "format": "prettier --write \"src/**/*.ts\" server.ts",
    "format:check": "prettier --check \"src/**/*.ts\" server.ts",
    "test": "ts-node-dev --transpile-only src/db/run-all-tests.ts"
  },
  "keywords": [
    "job-portal",
    "ai",
    "resume-analysis"
  ],
  "author": "",
  "license": "ISC",
  "description": "AI-Powered Job Application Portal - Backend API",
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "winston": "^3.19.0",
    "zod": "^3.23.8",
    "openai": "^4.73.0",
    "@google/generative-ai": "^0.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
