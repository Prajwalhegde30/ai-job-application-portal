# Server Configuration
NODE_ENV=production
PORT=8080

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT Secrets (Minimum 256-bit secure strings)
JWT_ACCESS_SECRET=your-jwt-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=your-jwt-refresh-secret-at-least-32-characters

# AI Configuration (mock | openai | gemini | openrouter)
AI_PROVIDER=mock
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key

# OpenRouter Configuration (required only when AI_PROVIDER=openrouter)
# API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
# Model slug — any model from https://openrouter.ai/models (default: openai/gpt-4o-mini-high:free)
OPENROUTER_MODEL=openai/gpt-4o-mini-high:free
# Base URL override (leave blank to use https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=

# Supabase Storage Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=resumes

# Network URLs
FRONTEND_URL=https://your-frontend-domain.vercel.app
BACKEND_URL=https://your-backend-domain.railway.app

# Optional Configurable Rate Limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_AUTH=20
RATE_LIMIT_MAX_AI_ANALYSIS=10
RATE_LIMIT_MAX_CAREER_ADVICE=15
RATE_LIMIT_MAX_MATCH_ANALYSIS=20
RATE_LIMIT_MAX_NOTIFICATIONS=100
