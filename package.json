{
  "name": "ai-job-portal",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Powered Job Application Portal with Resume Analysis",
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "format": "cd frontend && npm run format && cd ../backend && npm run format",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,tsx}": [
      "npx --prefix frontend prettier --write --config frontend/.prettierrc",
      "npx --prefix frontend eslint --fix --config frontend/eslint.config.mjs"
    ],
    "backend/src/**/*.ts": [
      "npx --prefix backend prettier --write --config backend/.prettierrc",
      "npx --prefix backend eslint --fix --config backend/eslint.config.mjs"
    ],
    "backend/server.ts": [
      "npx --prefix backend prettier --write --config backend/.prettierrc",
      "npx --prefix backend eslint --fix --config backend/eslint.config.mjs"
    ]
  }
}
